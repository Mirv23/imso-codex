# Note: En production, ces variables sont configurées comme Vercel Environment Variables
# via le script scripts/setup-vercel.ps1 (vercel env add PLAIN)
# Ce fichier sert uniquement de documentation et pour le développement local.

# Django
DJANGO_SECRET_KEY=<generer-avec-python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())">
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app,imsohaiti.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://imsohaiti.com,https://www.imsohaiti.com,https://imso-codex-mirv23s-projects.vercel.app
DJANGO_CORS_ALLOWED_ORIGINS=https://imsohaiti.com,https://www.imsohaiti.com
DJANGO_CORS_ALLOW_ALL_ORIGINS=False
DJANGO_LOG_LEVEL=INFO

# Security
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_HSTS_SECONDS=31536000
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True

# Cache / Redis (optionnel)
# Décommenter REDIS_URL pour activer Redis (caching + rate limiting partagé)
# Nécessite le service redis dans docker-compose.yml
# REDIS_URL=redis://redis:6379/1
# Sans Redis, le cache LocMemCache est utilisé (fallback).

# Database (SQLite local / PostgreSQL production)
DATABASE_URL=sqlite:///db.sqlite3

# Email (console en dev, SMTP en prod)
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.gmail.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_USER=
DJANGO_EMAIL_PASSWORD=
DJANGO_DEFAULT_FROM_EMAIL=noreply@imsohaiti.com
ADMIN_EMAIL=admin@imsohaiti.com

# File Storage (local en dev, S3 en prod)
DJANGO_FILE_STORAGE=django.core.files.storage.FileSystemStorage
# DJANGO_FILE_STORAGE=storages.backends.s3boto3.S3Boto3Storage
# DJANGO_S3_BUCKET=imso-media

# API interne
ADMIN_API_TOKEN=CHANGE_ME

# Webhook
WEBHOOK_SECRET=CHANGE_ME

# Paiement (clé pour confirmer les paiements)
PAYMENT_CONFIRM_KEY=CHANGE_ME

# Sentry (monitoring des erreurs)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
DJANGO_ENV=production
